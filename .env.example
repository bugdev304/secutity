# Variáveis de ambiente do pacote ae3/auth-security.
# Todas são opcionais — sem elas, os defaults abaixo (já usados em produção) valem.
# Copie os overrides que fizer sentido para o .env da app consumidora.

# Schema/modelo de usuário
AUTH_SECURITY_SCHEMA=
AUTH_SECURITY_USER_MODEL=

# Política de senha (TEC-03)
AUTH_SECURITY_PASSWORD_MIN_LENGTH=8
AUTH_SECURITY_PASSWORD_CLASSES_REQUIRED=3
AUTH_SECURITY_PASSWORD_COMMON_BLACKLIST=true
AUTH_SECURITY_PASSWORD_HISTORY_SIZE=3
AUTH_SECURITY_PASSWORD_EXPIRATION_DAYS=90

# MFA — parâmetros operacionais (TEC-01)
AUTH_SECURITY_OTP_VALIDITY_MINUTES=10
AUTH_SECURITY_OTP_LENGTH=6
AUTH_SECURITY_OTP_MAX_ATTEMPTS=5
AUTH_SECURITY_OTP_RESEND_LIMIT=3
AUTH_SECURITY_OTP_RESEND_INTERVAL_SECONDS=30
AUTH_SECURITY_SESSION_TTL_HOURS=8
AUTH_SECURITY_RECOVERY_CODES_COUNT=8
AUTH_SECURITY_RECOVERY_CODE_FORMAT=4-4-4-alpha
AUTH_SECURITY_TOTP_ALGORITHM=sha1
# Sem valor: cai para AUTH_SECURITY_TOTP_ISSUER -> APP_NAME -> "App", nessa ordem.
AUTH_SECURITY_TOTP_ISSUER=

# Bloqueio de conta (TEC-04)
AUTH_SECURITY_LOCKOUT_MAX_ATTEMPTS=5
AUTH_SECURITY_LOCKOUT_WINDOW_MINUTES=10
AUTH_SECURITY_LOCKOUT_UNLOCK_STRATEGY=admin_only

# Recuperação assistida (TEC-10)
AUTH_SECURITY_ASSISTED_RECOVERY_TOKEN_EXPIRES_HOURS=24

# Retenção de dados (LGPD Art. 15/16) — usadas por `php artisan auth-security:purge-expired-data`.
# Nada é eliminado automaticamente; a app decide se/quando agendar o comando.
AUTH_SECURITY_RETENTION_PENDING_FACTORS_DAYS=7
# Vazio = desativado (recomendado se a app tem obrigação legal de manter trilha de auditoria — Art. 16, I).
AUTH_SECURITY_RETENTION_ASSISTED_RECOVERIES_DAYS=

# Rotas — normalmente definidas via AuthSecurityServiceProvider::routes($prefix, $middleware, $guard)
# no routes/api.php da app; estas envs só valem quando routes() é chamado sem esses argumentos.
AUTH_SECURITY_ROUTES_PREFIX=auth-security
AUTH_SECURITY_ROUTES_GUARD=sanctum

# Cache
# Vazio = usa o driver de cache default da app.
AUTH_SECURITY_CACHE_DRIVER=
AUTH_SECURITY_CACHE_KEY_PREFIX=auth_security:
AUTH_SECURITY_CACHE_POLICY_TTL_MINUTES=5

# Rate limiting (throttle:auth-security:* nas rotas sensíveis)
AUTH_SECURITY_RATE_LIMIT_VERIFY_PER_MINUTE=10
AUTH_SECURITY_RATE_LIMIT_SEND_OTP_PER_MINUTE=5
AUTH_SECURITY_RATE_LIMIT_GENERATE_RECOVERY_PER_MINUTE=3
AUTH_SECURITY_RATE_LIMIT_ASSISTED_RECOVERY_PER_MINUTE=5

# Não configurável via .env (bindings de classe/arrays) — publique o config e edite direto:
# tenant_resolver, role_resolver, context_resolver, message_sender, audit_logger, floor_policy.roles_required
