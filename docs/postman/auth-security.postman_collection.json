{
  "info": {
    "name": "ae3/auth-security",
    "description": "Collection completa do pacote ae3/auth-security. Cobre MFA (OTP/TOTP), códigos de recuperação, recuperação assistida, políticas de organização e troca de senha.\n\nPré-requisito: configure o ambiente 'ae3-auth-security' e preencha {{access_token}} via login.\n\nFluxo sugerido: 0-Login → 1-Fatores → 2-Challenge → 3-Verify → 4-rotas protegidas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "ae3-auth-security-v1"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" },
    { "key": "prefix", "value": "{{prefix}}" }
  ],
  "item": [
    {
      "name": "0. Sandbox auth",
      "description": "Rotas de autenticação da app sandbox (fora do pacote). Usadas para obter o access_token Sanctum.",
      "item": [
        {
          "name": "POST /login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.environment.set('access_token', json.token); }",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sandbox_email}}\",\n  \"password\": \"{{sandbox_password}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "1. Fatores MFA",
      "description": "Cadastro e gestão de fatores MFA do usuário autenticado.",
      "item": [
        {
          "name": "GET /mfa/contacts — contatos disponíveis para cadastro",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OK', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "if (json.data && json.data[0]) {",
                  "  pm.environment.set('mfa_identifier', json.data[0].identifier);",
                  "  pm.environment.set('mfa_channel', json.data[0].channel);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/contacts", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "contacts"] }
          }
        },
        {
          "name": "GET /mfa/factors — listar confirmados",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors"] }
          }
        },
        {
          "name": "POST /mfa/factors — cadastrar e-mail (OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.environment.set('factor_id', json.data.id); }",
                  "pm.test('Criado', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"otp_email\",\n  \"identifier\": \"{{mfa_identifier}}\",\n  \"name\": \"E-mail pessoal\"\n}"
            }
          }
        },
        {
          "name": "POST /mfa/factors — cadastrar TOTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('factor_id', json.data.factor_id);",
                  "  pm.environment.set('totp_secret', json.data.secret);",
                  "}",
                  "pm.test('Criado', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"authenticator_app\",\n  \"holder_name\": \"Usuário Sandbox\",\n  \"name\": \"Meu autenticador\"\n}"
            }
          }
        },
        {
          "name": "POST /mfa/factors/{factor_id}/confirm — confirmar com OTP/TOTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors/{{factor_id}}/confirm", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors", "{{factor_id}}", "confirm"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "GET /mfa/factors/alternatives",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{prefix}}/mfa/factors/alternatives?exclude_factor_id={{factor_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{prefix}}", "mfa", "factors", "alternatives"],
              "query": [{ "key": "exclude_factor_id", "value": "{{factor_id}}" }]
            }
          }
        },
        {
          "name": "DELETE /mfa/factors/{factor_id}",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors/{{factor_id}}", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors", "{{factor_id}}"] }
          }
        }
      ]
    },
    {
      "name": "2. Verificação MFA (Challenge → Verify)",
      "description": "Solicitar e verificar código MFA. O verify retorna mfa_session_token.",
      "item": [
        {
          "name": "POST /mfa/factors/{factor_id}/challenge",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors/{{factor_id}}/challenge", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors", "{{factor_id}}", "challenge"] }
          }
        },
        {
          "name": "POST /mfa/factors/{factor_id}/challenge/resend",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/factors/{{factor_id}}/challenge/resend", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "factors", "{{factor_id}}", "challenge", "resend"] }
          }
        },
        {
          "name": "POST /mfa/verify — verificar código",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.mfa_session_token) {",
                  "  pm.environment.set('mfa_session_token', json.data.mfa_session_token);",
                  "}",
                  "pm.test('MFA verificado', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/verify", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "verify"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"factor_id\": \"{{factor_id}}\",\n  \"factor_type\": \"email\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST /mfa/recovery-codes/verify — usar código de recuperação",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.mfa_session_token) {",
                  "  pm.environment.set('mfa_session_token', json.data.mfa_session_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/recovery-codes/verify", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "recovery-codes", "verify"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"AAAA-BBBB-CCCC\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Códigos de recuperação",
      "description": "Metadados e geração de novos códigos. Codes plain-text retornados apenas 1x.",
      "item": [
        {
          "name": "GET /mfa/recovery-codes — metadados",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Mfa-Session-Token", "value": "{{mfa_session_token}}" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/recovery-codes", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "recovery-codes"] }
          }
        },
        {
          "name": "POST /mfa/recovery-codes — gerar (primeira vez)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Mfa-Session-Token", "value": "{{mfa_session_token}}" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/recovery-codes", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "recovery-codes"] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "POST /mfa/recovery-codes — gerar (forçar invalidação)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Mfa-Session-Token", "value": "{{mfa_session_token}}" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/recovery-codes", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "recovery-codes"] },
            "body": { "mode": "raw", "raw": "{\n  \"confirm_invalidation\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "4. Recuperação assistida",
      "description": "Fluxo TEC-11: Usuário solicita → Admin libera token → Usuário completa.",
      "item": [
        {
          "name": "POST /mfa/assisted-recoveries — solicitar (usuário)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.environment.set('recovery_id', json.data.id); }",
                  "pm.test('Criado', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/assisted-recoveries", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "assisted-recoveries"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_user_id\": {{user_id}},\n  \"reason_category\": \"device_lost\",\n  \"reason_text\": \"Perdi meu celular\"\n}"
            }
          }
        },
        {
          "name": "POST /mfa/assisted-recoveries/{recovery_id}/release — liberar (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.recovery_token) { pm.environment.set('recovery_token', json.data.recovery_token); }",
                  "pm.test('Token liberado', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/assisted-recoveries/{{recovery_id}}/release", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "assisted-recoveries", "{{recovery_id}}", "release"] }
          }
        },
        {
          "name": "POST /mfa/assisted-recoveries/complete — completar (usuário)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/assisted-recoveries/complete", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "assisted-recoveries", "complete"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{recovery_token}}\"\n}"
            }
          }
        },
        {
          "name": "POST /mfa/assisted-recoveries/{recovery_id}/refuse — recusar (admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/{{prefix}}/mfa/assisted-recoveries/{{recovery_id}}/refuse", "host": ["{{base_url}}"], "path": ["{{prefix}}", "mfa", "assisted-recoveries", "{{recovery_id}}", "refuse"] }
          }
        }
      ]
    },
    {
      "name": "5. Políticas de organização",
      "description": "Gestão de políticas MFA por tenant/role/contexto.",
      "item": [
        {
          "name": "GET /organization-policies?tenant_type=&tenant_id=",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{prefix}}/organization-policies?tenant_type=organization&tenant_id=1",
              "host": ["{{base_url}}"],
              "path": ["{{prefix}}", "organization-policies"],
              "query": [
                { "key": "tenant_type", "value": "organization" },
                { "key": "tenant_id", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "PUT /organization-policies — criar/atualizar",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/organization-policies", "host": ["{{base_url}}"], "path": ["{{prefix}}", "organization-policies"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_type\": \"organization\",\n  \"tenant_id\": 1,\n  \"role_type\": \"admin\",\n  \"role_id\": 1,\n  \"requires_mfa\": true,\n  \"context\": null\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Senha",
      "item": [
        {
          "name": "POST /password — alterar senha",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{prefix}}/password", "host": ["{{base_url}}"], "path": ["{{prefix}}", "password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_password\": \"NovaSenhaForte!1\",\n  \"new_password_confirmation\": \"NovaSenhaForte!1\"\n}"
            }
          }
        }
      ]
    }
  ]
}
